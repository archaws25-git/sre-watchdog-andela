# =============================================================================
# SRE Watchdog — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables have safe defaults for local development.
# NEVER commit a populated .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# SQLAlchemy-compatible connection string.
# For local development the default SQLite file is sufficient.
# For production, replace with a PostgreSQL or other supported URL.
# Default: sqlite:///./watchdog.db
DATABASE_URL=sqlite:///./watchdog.db


# -----------------------------------------------------------------------------
# AWS / Bedrock
# -----------------------------------------------------------------------------

# AWS region where Bedrock API calls are made.
# Ensure the chosen region has Bedrock model access enabled in your account.
# Default: us-east-1
AWS_REGION=us-east-1

# Bedrock model identifier used for anomaly analysis.
# Must be a model available in the configured AWS_REGION.
# Default: us.anthropic.claude-sonnet-4-5-20251101-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251101-v1:0

# Maximum number of log messages included in a single Bedrock analysis prompt.
# Capping this value controls token cost per inference call.
# Increase for richer context; decrease to reduce cost and latency.
# Default: 50
BEDROCK_MAX_LOG_SAMPLE=50


# -----------------------------------------------------------------------------
# Detection Thresholds
# -----------------------------------------------------------------------------

# Gate 1 (statistical pre-filter) threshold.
# If the error rate (ERROR + CRITICAL / total) within the sliding window
# exceeds this value, an anomaly window is created and Gate 2 is triggered.
# Must be a float in the range [0.0, 1.0].
# Default: 0.1  (10 % error rate)
ERROR_RATE_THRESHOLD=0.1

# Gate 2 (AI analysis) threshold.
# Bedrock anomaly scores at or above this value trigger alert dispatch.
# Must be a float in the range [0.0, 1.0].
# Default: 0.5
ANOMALY_SCORE_THRESHOLD=0.5


# -----------------------------------------------------------------------------
# Timing
# -----------------------------------------------------------------------------

# Width of the sliding window (in minutes) used to compute the per-service
# error rate during each APScheduler detection tick.
# Default: 5
SLIDING_WINDOW_MINUTES=5

# Minimum number of minutes that must elapse between alerts for the same
# service. During the cooldown window, Bedrock analysis still runs and
# results are persisted, but webhook dispatch is suppressed.
# Default: 15
ALERT_COOLDOWN_MINUTES=15

# Interval (in seconds) between APScheduler detection ticks.
# Lower values increase detection sensitivity at the cost of more DB queries.
# Default: 60
DETECTION_INTERVAL_SECONDS=60


# -----------------------------------------------------------------------------
# Ingestion
# -----------------------------------------------------------------------------

# Hard cap on the number of log entries accepted in a single
# POST /logs/ingest request. Requests exceeding this limit receive HTTP 413.
# Default: 500
MAX_INGEST_BATCH_SIZE=500


# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------

# Target URL for outbound alert webhook POST requests.
# In local development this points to the built-in echo endpoint.
# In production, replace with your on-call tool or incident management URL.
# Default: http://localhost:8000/webhooks/echo
WEBHOOK_URL=http://localhost:8000/webhooks/echo


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Python logging level for the application.
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Host address the Uvicorn server binds to.
# Use 0.0.0.0 to accept connections on all interfaces (required in containers).
# Default: 0.0.0.0
APP_HOST=0.0.0.0

# TCP port the Uvicorn server listens on.
# Default: 8000
APP_PORT=8000
